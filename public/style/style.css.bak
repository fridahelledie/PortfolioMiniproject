
/*colors
	#F4DDE5 = light pink
	#E7B9C8 = dark pink
	#D9D2C6 = beige
	#9DB5A3 = light green
	#2C3E35 = dark green

*/
body {
    font-family: "Monaco", monospace;
    margin: 0;
    padding: 0;
    background: #D9D2C6;
}

h1 {
	background-color:#2C3E35;
	padding:10px;
	text-align:center;
	margin:0;
	color: #F4DDE5;
}

h2 {
	background-color:#2C3E35;
	padding:10px;
	text-align:center;
	margin:0;
	color: #F4DDE5;
    clear: both;

}

nav {
    display: flex;
	background: #9DB5A3;
	padding: 10px;
}


nav li {
    list-style: none;
    display: inline-block;/*makes the list be vertical*/
    margin-right: 35px;
}

nav a {
    color: #2C3E35;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    text-decoration: underline;
}


/*select id tag_selection that is p
All <p> inside div #tag_selection*/
#tag_selection p {
	display: inline-block;
	font-size:120%;
	margin-left:15px;
	margin-top:25px;
	
		
	background: #E7B9C8;          /* default */
	border: 2px solid #F4DDE5;    /* lighter border */
	padding: 10px 14px;
	border-radius: 999px;         /* pill shape looks great for tags */
	
	
	/* 3D depth */
	box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.6), /* highlight */
    inset 0 -1px 0 rgba(0, 0, 0, 0.15),     /* inner shadow */
    0 4px 0 #C97D96,                        /* bottom edge */
    0 6px 10px rgba(0, 0, 0, 0.15);         /* drop shadow */

	
	transition:
    background 0.2s ease,
    border-color 0.2s ease,
    transform 0.15s ease,
    box-shadow 0.15s ease;


	cursor: pointer;
}

/*hover only when not chosen*/
#tag_selection p:hover:not(.chosen) {
	border-color: #D3809B; /*darker color*/
	transform: translateY(-2px); /* subtle lift */
	
	box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.6),
    inset 0 -1px 0 rgba(0, 0, 0, 0.1),
    0 6px 0 #C97D96,
    0 10px 16px rgba(0, 0, 0, 0.2);

}
/*when the button is chosen/clicked*/
#tag_selection p.chosen {
	background: #D3809B;         
	border-color: #B45C7A; /* darkest color */

	font-weight: 600;
}


#tag_selection p.chosen:hover {
	border-color: #B45C7A; /*darkest color*/

	transform: translateY(-2px); /* subtle lift */

	box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.6),
    inset 0 -1px 0 rgba(0, 0, 0, 0.1),
    0 6px 0 #B45C7A,
    0 10px 16px rgba(0, 0, 0, 0.2);
	
}


/*controls the layout of tags and sort*/
#controls_row {
  display: flex;
  align-items: center;
  margin-top: 20px;
}

#sort_controls {
  flex: 0 0 auto;      /* does NOT grow or shrink */
  white-space: nowrap;
  padding-right: 40px;
  margin-left: 40px;

}


#tag_selection {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;

  flex: 1;             /* takes all remaining space */
}



/*design of sorting button*/
#sort_controls select {
  padding: 6px 10px;
  border-radius: 6px;
  border: 2px solid #F4DDE5;

  background: #E7B9C8;
  font-size: 100%;
  cursor: pointer;
}






button {
    margin: 10px;
    padding: 10px 15px;
    background: #3D405B;
    border: none;
    color: white;
    border-radius: 5px;
    cursor: pointer;
}


footer {
    background: #2C3E35;
    color:#F4DDE5;
    margin-top: 40px;
	display: flex;
    justify-content: space-between;
    padding: 10px;
}


.footer-column {
    flex: 1;/* each column takes equal width */
    padding: 0 15px;
	text-align:left;
}

.footer-column h3 {
    margin-bottom: 10px;
}



.box-container {
    display: flex;
    justify-content: center;   /* centers both boxes as a group */
    gap: 10px;                 /* space between the boxes */
	position: relative;
}



.left-box {
    width: 43%;
    min-height: 400px;
}

.right-box {
    width: 43%;
    background: #9DB5A3;
    padding: 20px;
    margin: 40px;
    color: #2C3E35;
    min-height: 400px;
    border-radius: 25px;
    border: 2px solid #2C3E35;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
}


#portrait {
  max-width: 50%;
  display: block;
  margin: 0 auto;   /*centers horizontally */
  margin-top:40px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #E7B9C8;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3);
 

}


/*new an better grid portfolio*/
#project_browser {
	display: grid;
	grid-template-columns: repeat(2, minmax(0,1fr));
	gap: 20px;
	margin: 20px;
}

.project_card {
    background: #5D607B;
    padding: 15px;
    border-radius: 10px;
    color: white;
}

.project_card img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 6px;
}

.project_summary {
    width: 100%;
    margin: 10px 0;
	padding: 10px;
	color: white;
	background-color: 3D405B;
	border-radius: 6px;
}

.project_date {
	font-style: italic;
	color: white;
}

.project_card h2 {
	background-color:#2D304B;
	padding:10px;
	text-align:center;
	margin:0;
	color: #F4DDE5;
    clear: both;
	border-radius: 6px;
}

